<h1>Upcoming Events</h1>
<div style="display: flex; overflow-x: auto;">
  <% @events.each do |event| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin: 10px; width: 300px; text-align: center;">
      <img src="<%= event.image %>" style="width: 100%; height: 200px;">
      <h3><%= event.name %></h3>
      <p><%= event.description %></p>
      <p>Price: ₹<%= event.price %> per ticket</p>
      <p>Seats Left: <%= event.seats %></p>
      <%= link_to "Register", event_path(event), class: "btn btn-primary" %>
      <%= link_to "➕ Add Event", new_event_path, class: "btn btn-primary" %>

    </div>
  <% end %>
</div>

<div id="<%= dom_id event %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= event.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= event.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price:</strong>
    <%= event.price %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Seats:</strong>
    <%= event.seats %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Image:</strong>
    <%= event.image %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Date:</strong>
    <%= event.date %>
  </div>
</div>

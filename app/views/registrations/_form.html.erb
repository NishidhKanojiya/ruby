<%= form_with(model: registration, class: "contents") do |form| %>
  <% if registration.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(registration.errors.count, "error") %> prohibited this registration from being saved:</h2>

      <ul class="list-disc ml-6">
        <% registration.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :event_id %>
    <%= form.number_field :event_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": registration.errors[:event_id].none?, "border-red-400 focus:outline-red-600": registration.errors[:event_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": registration.errors[:name].none?, "border-red-400 focus:outline-red-600": registration.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :contact_number %>
    <%= form.text_field :contact_number, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": registration.errors[:contact_number].none?, "border-red-400 focus:outline-red-600": registration.errors[:contact_number].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :tickets %>
    <%= form.number_field :tickets, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": registration.errors[:tickets].none?, "border-red-400 focus:outline-red-600": registration.errors[:tickets].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :total_price %>
    <%= form.text_field :total_price, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": registration.errors[:total_price].none?, "border-red-400 focus:outline-red-600": registration.errors[:total_price].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>

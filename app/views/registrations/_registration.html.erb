<div id="<%= dom_id registration %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Event:</strong>
    <%= registration.event_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= registration.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Contact number:</strong>
    <%= registration.contact_number %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tickets:</strong>
    <%= registration.tickets %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Total price:</strong>
    <%= registration.total_price %>
  </div>
</div>
